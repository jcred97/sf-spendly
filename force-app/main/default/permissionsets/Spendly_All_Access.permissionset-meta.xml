<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Spendly All Access</label>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Object Permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Spending__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Category__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Expense__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Category__c Field Permissions -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Category__c.Display_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>Category__c.Total_Amount__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Expense__c Field Permissions -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Expense__c.Amount__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Expense__c.Bank__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>Expense__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Expense__c.Expense_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Expense__c.Transaction_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Tab Visibility -->
    <tabSettings>
        <tab>Expense__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Category__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Spending__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Spendly</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>SpendlyController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

</PermissionSet>
